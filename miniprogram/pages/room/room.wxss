.room {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  background: #0f171f;
}

.room-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.eyebrow {
  color: rgba(246, 240, 230, 0.58);
  font-size: 24rpx;
}

.room-id {
  margin-top: 4rpx;
  color: #f6f0e6;
  font-size: 52rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.role-chip {
  min-width: 96rpx;
  padding: 14rpx 18rpx;
  border-radius: 8rpx;
  color: #101820;
  background: #f2c14e;
  text-align: center;
  font-size: 24rpx;
  font-weight: 800;
}

.round-table {
  position: relative;
  height: 720rpx;
  margin-top: 8rpx;
}

.table-felt {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 520rpx;
  height: 360rpx;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background: #17634f;
  border: 18rpx solid #6d4a2f;
  box-shadow: 0 28rpx 70rpx rgba(0, 0, 0, 0.34), inset 0 0 0 8rpx rgba(255, 255, 255, 0.08);
  overflow: hidden;
}

.table-shine {
  position: absolute;
  left: 78rpx;
  top: 48rpx;
  width: 360rpx;
  height: 150rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.deck-stack {
  position: absolute;
  left: 50%;
  top: 116rpx;
  width: 108rpx;
  height: 148rpx;
  transform: translateX(-50%);
}

.deck-card {
  position: absolute;
  width: 92rpx;
  height: 128rpx;
  border-radius: 8rpx;
  background: #f6f0e6;
  border: 2rpx solid rgba(16, 24, 32, 0.16);
}

.card-a {
  left: 0;
  top: 12rpx;
  transform: rotate(-8deg);
}

.card-b {
  left: 10rpx;
  top: 4rpx;
  transform: rotate(4deg);
}

.card-c {
  left: 18rpx;
  top: 0;
  transform: rotate(12deg);
  background: #cf4747;
}

.table-title {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 72rpx;
  color: #f6f0e6;
  text-align: center;
  font-size: 34rpx;
  font-weight: 800;
}

.table-subtitle {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 40rpx;
  color: rgba(246, 240, 230, 0.68);
  text-align: center;
  font-size: 22rpx;
}

.seat {
  position: absolute;
  width: 208rpx;
  min-height: 104rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.09);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
}

.seat.dealer {
  border-color: #f2c14e;
  box-shadow: 0 0 0 4rpx rgba(242, 193, 78, 0.14);
}

.seat-0 {
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
}

.seat-1 {
  right: 0;
  bottom: 150rpx;
}

.seat-2 {
  right: 22rpx;
  top: 90rpx;
}

.seat-3 {
  left: 50%;
  top: 0;
  transform: translateX(-50%);
}

.seat-4 {
  left: 22rpx;
  top: 90rpx;
}

.seat-5 {
  left: 0;
  bottom: 150rpx;
}

.avatar {
  width: 58rpx;
  height: 58rpx;
  flex: 0 0 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #8fd5a6;
  color: #101820;
  font-weight: 800;
}

.seat-copy {
  min-width: 0;
}

.seat-name {
  color: #f6f0e6;
  font-size: 26rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.seat-note {
  margin-top: 4rpx;
  color: rgba(246, 240, 230, 0.62);
  font-size: 22rpx;
}

.rules-panel {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.rule-pill {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(246, 240, 230, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  font-size: 24rpx;
}

.demo-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
  margin-top: auto;
}

.start-button {
  margin-top: auto;
  min-height: 92rpx;
}
