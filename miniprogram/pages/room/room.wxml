<view class="page room">
  <view class="room-top">
    <view>
      <view class="eyebrow">房间配对码</view>
      <view class="room-id">{{roomId}}</view>
    </view>
    <view class="role-chip">{{isOwner ? '房主' : '玩家'}}</view>
  </view>
  <view class="status-card">
    <view class="status-main">{{statusText}}</view>
    <view class="status-sub">准备 {{readyCount}}/{{targetCount}} · 人数 {{players.length}}/{{targetCount}}</view>
  </view>

  <view class="round-table">
    <view class="table-felt">
      <image class="table-image" src="/assets/ui/poker-table-felt.jpg" mode="aspectFill"></image>
      <view class="table-shine"></view>
      <view class="deck-stack">
        <view class="deck-card card-a"></view>
        <view class="deck-card card-b"></view>
        <view class="deck-card card-c"></view>
      </view>
      <view class="table-title">{{countdown ? countdown + '秒后开始' : '等待开局'}}</view>
      <view class="table-subtitle">{{isFull ? '全员准备后自动开始' : '把配对码发给其他玩家'}}</view>
    </view>

    <view class="seat seat-{{index}} {{item.isDealer ? 'dealer' : ''}} {{item.ready ? 'ready' : ''}}" wx:for="{{players}}" wx:key="id">
      <view class="avatar">{{item.name[0]}}</view>
      <view class="seat-copy">
        <view class="seat-name">{{item.name}}</view>
        <view class="seat-note">{{item.isDealer ? '庄家' : '闲家'}} · {{item.ready ? '已准备' : '未准备'}}</view>
      </view>
    </view>
  </view>

  <view class="rules-panel">
    <view class="rule-pill">2-10 人</view>
    <view class="rule-pill">大小王万能</view>
    <view class="rule-pill">235 吃豹子</view>
    <view class="rule-pill">蒙牌翻倍</view>
  </view>

  <view class="demo-actions">
    <button class="primary-button start-button icon-button" bindtap="toggleReady">
      <image class="button-icon" src="/assets/ui/icon-ready.png" mode="aspectFit"></image>
      <text>{{myReady ? '取消准备' : '我已准备'}}</text>
    </button>
    <view class="socket-note">{{connected ? '联机中：等待其他玩家操作' : '未连接房间服务'}}</view>
  </view>
</view>
