.home {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 32rpx;
}

.brand {
  font-size: 64rpx;
  font-weight: 800;
  line-height: 1.1;
}

.subtitle {
  color: rgba(246, 240, 230, 0.72);
  font-size: 30rpx;
}

.panel {
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.06);
  border-radius: 8rpx;
}

.field-label {
  font-size: 26rpx;
  color: rgba(246, 240, 230, 0.7);
  margin-bottom: 12rpx;
}

.input {
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.24);
  color: #f6f0e6;
  margin-bottom: 24rpx;
}

.action {
  margin-top: 20rpx;
}

.rule-strip {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  font-size: 24rpx;
  color: #101820;
}

.rule-strip view {
  background: #8fd5a6;
  padding: 16rpx 8rpx;
  text-align: center;
  border-radius: 8rpx;
  font-weight: 700;
}
