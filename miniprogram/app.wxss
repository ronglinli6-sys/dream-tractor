page {
  min-height: 100%;
  background: #0f171f;
  color: #f6f0e6;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

button {
  border-radius: 8px;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx;
}

.primary-button {
  background: #f2c14e;
  color: #101820;
  font-weight: 700;
}

.ghost-button {
  background: rgba(255, 255, 255, 0.08);
  color: #f6f0e6;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}

.muted {
  color: rgba(246, 240, 230, 0.68);
}
